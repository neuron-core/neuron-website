---
import Typography from '~components/ui/Typography.astro';
---

<div class="wrapper">
  <div class="content">
    <div class="inner">
      <Typography tag="span" styling="paragraphM" font="pixel" color="agents">
        NEURON AI / PARTNER NETWORK
      </Typography>
      <Typography tag="h1" styling="headingXl">
        Neuron AI Partner<br />Network
      </Typography>
      <Typography tag="p" styling="paragraphL" color="subtle" class="lede">
        Connect with <strong>vetted</strong> software houses and agencies building production-ready Agentic AI. Our partners are experienced teams who leverage the PHP stack to deliver scalable AI solutions.
      </Typography>
    </div>
  </div>
  <div class="stripe">
    <div class="bar agents" />
    <div class="bar workflows" />
    <div class="bar vector" />
    <div class="bar monitoring" />
  </div>
</div>

<style lang="scss">
  @use '~styles/mixins/media' as *;

  .wrapper {
    width: 100%;
    border-bottom: 1px solid var(--border-soft);
  }

  .content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--s-64) 0;

    @include media-min('lg') {
      padding: var(--s-100) 0 var(--s-64);
    }
  }

  .inner {
    display: flex;
    flex-direction: column;
    gap: var(--s-24);
  }

  .lede {
    max-width: 640px;
    padding-top: var(--s-12);
  }

  .stripe {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    height: 8px;
  }

  .agents {
    background: var(--bg-agents-base);
  }

  .workflows {
    background: var(--bg-workflows-base);
  }

  .vector {
    background: var(--bg-vector-base);
  }

  .monitoring {
    background: var(--bg-monitoring-base);
  }
</style>
