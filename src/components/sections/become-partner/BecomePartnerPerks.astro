---
import Typography from '~components/ui/Typography.astro';

const PERKS = [
  {
    title: 'Technical Visibility',
    body: "Get featured on our official partners' showcase to reach CTOs looking for proven AI implementation partners.",
  },
  {
    title: 'Official Partner Badge',
    body: 'Receive the official "Neuron AI Partner" digital badge to display on your website and documentation, certifying your active role in the ecosystem.',
  },
  {
    title: 'Direct Core Access',
    body: "A priority channel for technical Q&A with Neuron's core developers. We help you unblock complex architectural challenges.",
  },
  {
    title: 'Monthly Technical Call',
    body: 'A dedicated session to discuss the roadmap, preview upcoming features, and get direct feedback on your production use cases.',
  },
  {
    title: 'Joint Marketing & Social Amplification',
    body: "We don't just list your logo; we promote your expertise. Benefit from featured placement on neuron-ai.dev, dedicated social media spotlights, and joint case studies. We amplify your innovations to our specialized PHP community to build your authority as a leader in Agentic AI.",
  },
  {
    title: 'Documentation Indexing',
    body: 'Showcase your custom connectors or extensions in our official "Neuron Hub" section to demonstrate technical authority.',
  },
  {
    title: 'Ecosystem Perks',
    body: 'Access exclusive bonuses and service credits shared within our network of professional AI supporters.',
  },
];
---

<div class="wrapper">
  <div class="content">
    <div class="leftCol">
      <Typography tag="span" styling="paragraphM" font="pixel" color="monitoring">
        THE PARTNERSHIP PERKS
      </Typography>
      <Typography tag="h2" styling="headingL">
        Grow your expertise as a Neuron Partner.
      </Typography>
      <Typography tag="p" styling="paragraphL" color="subtle" class="subtitle">
        Joining the Neuron Partner Network is about positioning your team at the core of the PHP AI transition. It's a technical alliance designed for those who are actively shipping AI agents to production.
      </Typography>
    </div>
    <ol class="list">
      {PERKS.map((perk, i) => (
        <li class:list={[{ first: i === 0 }]}>
          <span class="number">
            {String(i + 1).padStart(2, '0')} /
          </span>
          <div class="itemContent">
            <Typography tag="h3" styling="headingS" class="itemTitle">
              {perk.title}
            </Typography>
            <Typography tag="p" styling="paragraphL" color="subtle" class="itemBody">
              {perk.body}
            </Typography>
          </div>
        </li>
      ))}
    </ol>
  </div>
</div>

<style lang="scss">
  @use '~styles/mixins/media' as *;

  .wrapper {
    width: 100%;
    border-top: 1px solid var(--border-soft);
  }

  .content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-46);
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--s-64) 0;

    @include media-min('lg') {
      grid-template-columns: 1fr 1.6fr;
      gap: var(--s-64);
      padding: var(--s-100) 0;
    }
  }

  .leftCol {
    display: flex;
    flex-direction: column;
    gap: var(--s-20);

    @include media-min('lg') {
      position: sticky;
      top: var(--s-100);
      align-self: start;
    }
  }

  .subtitle {
    margin: 0;
    margin-top: var(--s-12);
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  li {
    display: flex;
    gap: var(--s-32);
    padding: var(--s-46) 0;
    border-bottom: 1px solid var(--border-soft);
    align-items: baseline;

    &.first {
      border-top: 1px solid var(--border-soft);
    }
  }

  .number {
    font-weight: 700;
    font-size: 2.4rem;
    color: var(--bg-monitoring-base);
    font-family: GeistPixel, sans-serif;
    line-height: 1.3;
    min-width: 5.6rem;
    margin: 0;
    flex-shrink: 0;
  }

  .itemContent {
    display: flex;
    flex-direction: column;
    gap: var(--s-12);
    flex: 1;
  }

  .itemTitle {
    font-weight: 500;
    margin: 0;
  }

  .itemBody {
    margin: 0;
    max-width: 640px;
  }
</style>
