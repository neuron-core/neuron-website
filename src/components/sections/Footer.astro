---
import { Image } from 'astro:assets';
import Typography from '~components/ui/Typography.astro';
import neuronLogo from '~assets/icons/neuron-logo.svg';
import neuronLogoFooter from '~assets/illustrations/neuron-logo-footer.svg';
import { LANDING_SECTIONS } from '~consts/landingSections';

const columns = [
  {
    title: 'NEURON AI',
    links: [
      { text: 'Documentation', href: 'https://docs.neuron-ai.dev/' },
      {
        text: 'Video Tutorials',
        href: `#${LANDING_SECTIONS.VIDEO_TUTORIALS}`,
      },
      { text: 'Github', href: 'https://github.com/neuron-core/neuron-ai' },
    ],
  },
  {
    title: 'RESOURCES',
    links: [
      { text: 'Features', href: `#${LANDING_SECTIONS.FEATURES}` },
      { text: 'Code Examples', href: `#${LANDING_SECTIONS.CODE}` },
      { text: 'Use Cases', href: `#${LANDING_SECTIONS.USE_CASES}` },
    ],
  },
  {
    title: 'ECOSYSTEM',
    links: [
      { text: 'Inspector.dev', href: 'https://inspector.dev/' },
      { text: 'Neuron Hub', href: 'https://neuronhub.dev/' },
      { text: 'Newsletter', href: `#${LANDING_SECTIONS.NEWSLETTER}` },
    ],
  },
  {
    title: 'COMPANY',
    links: [
      { text: 'About Inspector', href: 'https://inspector.dev/' },
      {
        text: 'Partners',
        href: '/partners',
      },
      {
        text: 'Github Organization',
        href: 'https://github.com/neuron-core',
      },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="content">
    <div class="topRow">
      <div class="brand">
        <div class="logo">
          <Image src={neuronLogo} alt="Neuron" width={135} height={36} />
        </div>

        <Typography
          tag="p"
          styling="paragraphM"
          color="primary"
          class="tagline"
        >
          The First Agentic Framework Of The PHP Ecosystem
        </Typography>

        <Typography
          tag="span"
          styling="paragraphS"
          color="soft"
          class="copyright"
        >
          Copyright © Neuron AI {currentYear}. All rights reserved.
        </Typography>
      </div>

      <div class="columns">
        {
          columns.map((column) => (
            <div class="column">
              <Typography
                tag="span"
                styling="paragraphM"
                font="pixel"
                color="primary"
              >
                {column.title}
              </Typography>

              <ul class="linkList">
                {column.links.map((link) => (
                  <li>
                    <a
                      class="link"
                      href={link.href}
                      target={
                        link.href.startsWith('http') ? '_blank' : undefined
                      }
                      rel={
                        link.href.startsWith('http')
                          ? 'noopener noreferrer'
                          : undefined
                      }
                    >
                      <Typography
                        tag="span"
                        styling="paragraphM"
                        color="subtle"
                      >
                        {link.text}
                      </Typography>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="bigLogo">
      <Image src={neuronLogoFooter} alt="Neuron" />
    </div>
  </div>
</footer>

<style lang="scss">
  @use '~styles/mixins/media' as *;

  .footer {
    width: 100%;
    margin-top: var(--s-100);
    border-top: 1px solid var(--border-soft);
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: var(--s-100);

    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--s-64) var(--s-20);

    @include media-min('md') {
      padding: var(--s-64) var(--s-32);
    }
  }

  .topRow {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-46);

    @include media-min('md') {
      grid-template-columns: 2fr 3fr;
      gap: var(--s-64);
    }
  }

  .brand {
    display: flex;
    flex-direction: column;
    gap: var(--s-24);
  }

  .logo img {
    display: block;
  }

  .brand :global(.tagline) {
    margin: 0;
  }

  .brand :global(.copyright) {
    margin-top: var(--s-24);
  }

  .columns {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-32);

    @include media-min('md') {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .column {
    display: flex;
    flex-direction: column;
    gap: var(--s-24);
  }

  .linkList {
    display: flex;
    flex-direction: column;
    gap: var(--s-12);

    margin: 0;
    padding: 0;

    list-style: none;
  }

  .link {
    color: var(--text-subtle);
    text-decoration: none;

    &:hover {
      color: var(--text-primary);
    }
  }

  .bigLogo {
    width: 100%;

    img {
      width: 100%;
      height: auto;
    }
  }
</style>
