---
import Typography from '~components/ui/Typography.astro';
import Button from '~components/ui/Button.astro';
---

<div class="wrapper">
  <div class="content">
    <div class="card">
      <div class="stripe">
        <div class="bar agents" />
        <div class="bar workflows" />
        <div class="bar vector" />
        <div class="bar monitoring" />
      </div>
      <div class="cardInner">
        <Typography tag="span" styling="paragraphM" font="pixel" color="soft" class="eyebrow">
          APPLICATIONS REVIEWED MONTHLY
        </Typography>
        <Typography tag="h2" styling="headingL" class="heading">
          Run a PHP company shipping AI in production?<br />Apply to the partner program.
        </Typography>
        <Typography tag="p" styling="paragraphL" color="subtle" class="body">
          Send a short note about your team, your stack and one Neuron AI workload you've shipped or want to ship. We'll reply within five business days.
        </Typography>
        <div class="ctas">
          <Button
            href="mailto:support@inspector.dev?subject=Neuron%20AI%20Partner%20Program%20Application"
            text="become a partner"
          />
        </div>
      </div>
    </div>
  </div>
</div>

<style lang="scss">
  @use '~styles/mixins/media' as *;

  .wrapper {
    width: 100%;
  }

  .content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--s-64) 0;

    @include media-min('lg') {
      padding: var(--s-100) 0;
    }
  }

  .card {
    border: 1px solid var(--border-soft);
    background: var(--bg-weak);
  }

  .stripe {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    height: 8px;
  }

  .agents {
    background: var(--bg-agents-base);
  }

  .workflows {
    background: var(--bg-workflows-base);
  }

  .vector {
    background: var(--bg-vector-base);
  }

  .monitoring {
    background: var(--bg-monitoring-base);
  }

  .cardInner {
    padding: var(--s-46) var(--s-24);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-24);

    @include media-min('md') {
      padding: var(--s-64) var(--s-46);
    }
  }

  .eyebrow {
    margin: 0;
    font-size: 1.3rem;
    letter-spacing: 0.08em;
  }

  .heading {
    margin: 0;
    max-width: 900px;
  }

  .body {
    margin: 0;
    max-width: 620px;
  }

  .ctas {
    display: flex;
    gap: var(--s-12);
    flex-wrap: wrap;
    margin-top: var(--s-12);
  }
</style>
