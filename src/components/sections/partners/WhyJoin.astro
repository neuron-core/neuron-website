---
import Typography from '~components/ui/Typography.astro';

const WHY_JOIN_ITEMS = [
  {
    title: 'Direct line to the maintainers',
    body: 'Monthly office hours with the Neuron AI core team, a private Slack channel, and roadmap previews before they ship. Your customers know you\'re never more than a message away from the source.',
  },
  {
    title: 'Preferential ecosystem terms',
    body: 'Discounted Inspector.dev tiers and partners services, priority NeuronHub listings, and shared benefits on referrals. Bring your customers the whole stack at terms only partners get.',
  },
  {
    title: 'Co-marketing and lead routing',
    body: 'Featured placement on neuron-ai.dev, joint case studies, and inbound leads matched on region and specialty. Your authority becomes part of how the framework reaches enterprise PHP.',
  },
  {
    title: 'Experience that means something',
    body: 'Every partner ships at least one Neuron AI workload in production before listing. We vet, we onboard, we keep the bar high — so the badge keeps its weight.',
  },
];
---

<div class="wrapper">
  <div class="content">
    <div class="leftCol">
      <Typography tag="span" styling="paragraphM" font="pixel" color="monitoring">
        WHY JOIN
      </Typography>
      <Typography tag="h2" styling="headingL">
        Built for teams who ship.
      </Typography>
      <Typography tag="p" styling="paragraphL" color="subtle" class="subtitle">
        The partner program is selective on purpose. Four guarantees, in writing, for every partner.
      </Typography>
    </div>
    <ol class="list">
      {WHY_JOIN_ITEMS.map((item, i) => (
        <li class:list={[{ first: i === 0 }]}>
          <span class="number">
            {String(i + 1).padStart(2, '0')} /
          </span>
          <div class="itemContent">
            <Typography tag="h3" styling="headingS" class="itemTitle">
              {item.title}
            </Typography>
            <Typography tag="p" styling="paragraphL" color="subtle" class="itemBody">
              {item.body}
            </Typography>
          </div>
        </li>
      ))}
    </ol>
  </div>
</div>

<style lang="scss">
  @use '~styles/mixins/media' as *;

  .wrapper {
    width: 100%;
    border-top: 1px solid var(--border-soft);
  }

  .content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-46);
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--s-64) 0;

    @include media-min('lg') {
      grid-template-columns: 1fr 1.6fr;
      gap: var(--s-64);
      padding: var(--s-100) 0;
    }
  }

  .leftCol {
    display: flex;
    flex-direction: column;
    gap: var(--s-20);

    @include media-min('lg') {
      position: sticky;
      top: var(--s-100);
      align-self: start;
    }
  }

  .eyebrow {
    margin: 0;
    color: var(--bg-monitoring-base);
    font-family: GeistPixel, sans-serif;
    font-size: 1.3rem;
    letter-spacing: 0.08em;
  }

  .subtitle {
    margin: 0;
    margin-top: var(--s-12);
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  li {
    display: flex;
    gap: var(--s-32);
    padding: var(--s-46) 0;
    border-bottom: 1px solid var(--border-soft);
    align-items: baseline;

    &.first {
      border-top: 1px solid var(--border-soft);
    }
  }

  .number {
    font-weight: 700;
    font-size: 2.4rem;
    color: var(--bg-monitoring-base);
    font-family: GeistPixel, sans-serif;
    line-height: 1.3;
    min-width: 5.6rem;
    margin: 0;
    flex-shrink: 0;
  }

  .itemContent {
    display: flex;
    flex-direction: column;
    gap: var(--s-12);
    flex: 1;
  }

  .itemTitle {
    font-weight: 500;
    margin: 0;
  }

  .itemBody {
    margin: 0;
    max-width: 640px;
  }
</style>
