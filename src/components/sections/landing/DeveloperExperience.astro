---
import fs from 'node:fs';
import path from 'node:path';
import Typography from '~components/ui/Typography.astro';

const iconsDir = path.resolve('src/assets/icons');

const bracesIcon = fs.readFileSync(path.join(iconsDir, 'braces.svg'), 'utf-8');
const doubleCheckIcon = fs.readFileSync(
  path.join(iconsDir, 'double-check.svg'),
  'utf-8',
);
const cursorInputIcon = fs.readFileSync(
  path.join(iconsDir, 'cursor-input.svg'),
  'utf-8',
);
const blocksIcon = fs.readFileSync(path.join(iconsDir, 'blocks.svg'), 'utf-8');

const cards = [
  {
    title: 'Fully Typed',
    description:
      'Every method, property, and return value is explicitly typed for maximum IDE support and type safety.',
    color: 'var(--bg-workflows-base)',
    icon: bracesIcon,
  },
  {
    title: 'PHPStan 100% coverage',
    description:
      'Complete type coverage across the entire framework ensures reliability and maintainability.',
    color: 'var(--bg-agents-base)',
    icon: doubleCheckIcon,
  },
  {
    title: 'Coding Agent Friendly',
    description:
      'Let AI Coding Assistants know how to create Neuron AI agentic systems with our integrated skills, or connect directly with the documentation through the MCP server.',
    color: 'var(--bg-vector-base)',
    icon: cursorInputIcon,
  },
  {
    title: 'Flexible Architecture',
    description:
      'Neuron integrates seamlessly with your existing codebase without refactoring or disrupting established environments.',
    color: 'var(--bg-monitoring-base)',
    icon: blocksIcon,
  },
];
---

<div class="wrapper">
  <div class="content">
    <Typography tag="h2" styling="headingL" align="center">
      A framework designed for the <br />best developer experience
    </Typography>

    <div class="cards">
      {
        cards.map((item) => (
          <div class="card" style={`--card-color: ${item.color};`}>
            <div class="topLine" />
            <div class="icon" set:html={item.icon} />

            <div class="cardBody">
              <Typography tag="h3" styling="headingS">
                {item.title}
              </Typography>
              <Typography
                tag="p"
                class="description"
                color="subtle"
                styling="paragraphL"
              >
                {item.description}
              </Typography>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style lang="scss">
  @use '~styles/mixins/media' as *;

  .wrapper {
    width: 100%;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: var(--s-64);
    align-items: center;

    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--s-64) 0;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    width: 100%;
    border: 1px solid var(--border-soft);

    @include media-min('sm') {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .card {
    position: relative;

    display: flex;
    flex-direction: column;

    padding: var(--s-24) var(--s-20);
    border-bottom: 1px solid var(--border-soft);

    &:last-child {
      border-bottom: none;
    }

    @include media-min('sm') {
      padding: var(--s-32) var(--s-24);
      border-right: 1px solid var(--border-soft);

      &:nth-child(2n) {
        border-right: none;
      }

      &:nth-last-child(-n + 2) {
        border-bottom: none;
      }
    }
  }

  .topLine {
    position: absolute;
    z-index: var(--z-index-high);
    top: 1px;
    right: 0;
    left: 0;

    height: 4px;

    background-color: var(--card-color);
  }

  .icon {
    width: 3.6rem;
    color: var(--text-primary);

    @include media-min('sm') {
      width: var(--s-36);
    }
  }

  .cardBody {
    display: flex;
    flex-direction: column;
    margin-top: var(--s-28);
  }

  .cardBody :global(.description) {
    margin-top: var(--s-16);
    margin-bottom: 0;
  }
</style>
