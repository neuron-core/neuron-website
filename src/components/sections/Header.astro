---
import { Image } from 'astro:assets';
import Typography from '~components/ui/Typography.astro';
import Button from '~components/ui/Button.astro';
import neuronLogo from '~assets/icons/neuron-logo.svg';
import { LANDING_SECTIONS } from '~consts/landingSections';

interface Props {
  currentPage?: 'home' | 'partners';
}

const { currentPage = 'home' } = Astro.props as Props;

const links = [
  {
    text: 'Features',
    href: `/#${LANDING_SECTIONS.FEATURES}`,
  },
  {
    text: 'Code',
    href: `/#${LANDING_SECTIONS.CODE}`,
  },
  {
    text: 'Use Cases',
    href: `/#${LANDING_SECTIONS.USE_CASES}`,
  },
  {
    text: 'Book',
    href: `/#${LANDING_SECTIONS.BOOK}`,
  },
];

const pageLinks = [
  { text: 'Home', href: '/', page: 'home' as const },
  { text: 'Partners', href: '/partners', page: 'partners' as const },
];
---

<header>
  <div class="content">
    <a href="/" class="logoLink">
      <Image src={neuronLogo} alt="Neuron" width={135} height={36} />
    </a>

    <div class="rightSide">
      <div class="pageLinks">
        {
          pageLinks.map((item) => (
            <a
              href={item.href}
              class:list={[{ active: currentPage === item.page }]}
            >
              <Typography styling="paragraphM" tag="span">
                {item.text}
              </Typography>
            </a>
          ))
        }
      </div>

      <div class="links">
        {
          links.map((item) => {
            return (
              <a href={item.href}>
                <Typography styling="paragraphM" tag="span">
                  {item.text}
                </Typography>
              </a>
            );
          })
        }
      </div>

      <div class="buttons">
        <Button href="https://github.com/neuron-core/neuron-ai" text="github" variant="outline" />
        <Button href="https://docs.neuron-ai.dev/" text="read docs" />
      </div>
    </div>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: var(--z-index-high);
    width: 100%;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-soft);
  }

  .content {
    display: flex;
    align-items: center;
    justify-content: space-between;

    width: 100%;
    max-width: var(--max-width);
    height: 74px;
    margin: 0 auto;
  }

  .logoLink {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .rightSide {
    display: flex;
    gap: var(--s-32);
    align-items: center;
  }

  .pageLinks {
    display: flex;
    gap: var(--s-24);
    align-items: center;

    a {
      color: var(--text-subtle);
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover {
        color: var(--text-primary);
      }

      &.active {
        color: var(--text-primary);
      }
    }
  }

  .links {
    display: flex;
    gap: var(--s-24);
    align-items: center;

    a {
      color: var(--text-primary);
      text-decoration: none;
    }
  }

  .buttons {
    display: flex;
    gap: var(--s-12);
  }
</style>
