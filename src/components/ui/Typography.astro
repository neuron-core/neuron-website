---
type TypographyTags =
  | 'h1'
  | 'h2'
  | 'h3'
  | 'h4'
  | 'h5'
  | 'h6'
  | 'p'
  | 'label'
  | 'span';
type Styling =
  | 'headingXl'
  | 'headingL'
  | 'headingM'
  | 'headingS'
  | 'headingXs'
  | 'bodyL'
  | 'bodyM'
  | 'bodyS'
  | 'paragraphL'
  | 'paragraphM'
  | 'paragraphS';

type PixelWeight = 'square' | 'grid' | 'triangle';

interface Props {
  tag: TypographyTags;
  styling?: Styling;
  color?:
    | 'primary'
    | 'weak'
    | 'subtle'
    | 'soft'
    | 'disabled'
    | 'heavy'
    | 'strong';
  class?: string;
  align?: 'left' | 'center' | 'right';
  font?: 'normal' | 'pixel';
  pixelWeight?: PixelWeight;
}

const map: Record<TypographyTags, Styling> = {
  h1: 'headingXl',
  h2: 'headingL',
  h3: 'headingM',
  h4: 'headingS',
  h5: 'headingXs',
  h6: 'headingXs',
  p: 'paragraphL',
  label: 'paragraphL',
  span: 'paragraphL',
};

const pixelWeightMap: Record<PixelWeight, number> = {
  square: 400,
  grid: 300,
  triangle: 700,
};

const {
  tag,
  styling,
  color = 'primary',
  class: className,
  align,
  pixelWeight = 'square',
  font = 'normal',
} = Astro.props as Props;
const Element = tag;
const elementStyle = styling ?? map[tag];

const weight = pixelWeightMap[pixelWeight];

const styles = {
  color: `var(--text-${color})`,
  ...(font === 'pixel' && { 'font-weight': weight }),
};
---

<Element
  class:list={[className, elementStyle, color, 'container', align, font]}
  style={styles}
>
  <slot />
</Element>

<style>
  .container {
    margin: 0;
  }

  .center {
    text-align: center;
  }

  .left {
    text-align: left;
  }

  .right {
    text-align: right;
  }

  .normal {
    font-family: Inter, sans-serif;
  }

  .pixel {
    font-family: GeistPixel, sans-serif;
  }
</style>
